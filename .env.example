# Copy to .env and fill in your values
# Never commit .env

# Supabase (from your project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Also needed by the Next.js frontend (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Worker webhook secret — generate with: openssl rand -hex 32
WORKER_WEBHOOK_SECRET=your-secret

# Optional: Anthropic API key (only needed for Railway/cloud worker)
# Leave blank when using the local claude CLI worker
ANTHROPIC_API_KEY=
