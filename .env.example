# Copy to .env and fill in your values. Never commit .env.
#
# Only a subset is needed depending on which surface you run:
#   - MCP / CLI (local stdio) : nothing required — uses your Claude CLI session.
#   - MCP / CLI (with API key): set ANTHROPIC_API_KEY.
#   - Self-hosted web product  : set everything below.

# --- Anthropic ---
# Optional. If unset, the worker shells out to the `claude` CLI and uses
# your Claude subscription instead of token billing.
ANTHROPIC_API_KEY=

# --- Supabase (web product only) ---
# https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Worker webhook (web product only) ---
# Shared secret between Next.js API routes and the Python worker.
# Generate with: openssl rand -hex 32
WORKER_WEBHOOK_SECRET=your-secret
WORKER_URL=http://localhost:8001

# --- Email notifications (web product only) ---
# https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM=spectr <onboarding@resend.dev>
# Where new-signup notifications are sent.
FOUNDER_EMAIL=hello@spectr.to

# --- Stripe (web product, paid path only) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Single flat price, reused by BOTH the "generate your own" prepay and the
# per-app gallery spec purchase.
STRIPE_PRICE_ID=
# Higher price for the per-category bundle ("Get all <category> app specs").
STRIPE_PRICE_ID_CATEGORY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# 'true' = charge for the gallery (generate-your-own + per-app spec packs).
# Anything else = local-dev bypass: specs download free, no Stripe round-trip.
# Must be 'true' in production or the paid specs are given away.
NEXT_PUBLIC_GALLERY_PAYWALL_ENABLED=true

# --- Misc ---
# Site origin used for redirects (checkout success URLs, magic-link callbacks).
SITE_URL=http://localhost:3000
# Guards the /admin dashboard.
ADMIN_SECRET=
